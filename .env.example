# Copia este archivo a .env.local y completa el valor.
# .env.local está en .gitignore y NUNCA debe subirse al repo.

# Clave de Google Gemini — SOLO SERVIDOR (sin prefijo NEXT_PUBLIC_).
# La usa únicamente /app/api/gemini/route.ts; jamás llega al navegador.
# Consíguela gratis en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_clave_aqui

# Supabase — biblioteca pública compartida (auth + catálogo de libros).
# La anon key es pública por diseño (el acceso lo restringe RLS).
# Panel del proyecto → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key

# Service role key — SOLO SERVIDOR (saltea RLS). La usa el webhook de Lemon
# Squeezy para escribir membresías. NUNCA con prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key
# Opcional: URL de Supabase para el servidor (si difiere de la pública).
# SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Lemon Squeezy — membresías (Merchant of Record).
# Signing secret del webhook (Settings → Webhooks). SOLO SERVIDOR.
LEMONSQUEEZY_WEBHOOK_SECRET=tu_signing_secret
# Links de checkout hosted de cada plan (Store → Products → Share/Buy link).
# Son públicos (build args): se inlinean en el bundle del cliente.
NEXT_PUBLIC_LS_CHECKOUT_MONTHLY=https://TU-TIENDA.lemonsqueezy.com/buy/UUID-MENSUAL
NEXT_PUBLIC_LS_CHECKOUT_YEARLY=https://TU-TIENDA.lemonsqueezy.com/buy/UUID-ANUAL

# Paywall de membresías: OFF por defecto (todo gratis). Poné "true" para activar
# el cobro de la biblioteca pública + módulos. Es build arg (hay que reconstruir).
NEXT_PUBLIC_MEMBERSHIP_ENABLED=false
